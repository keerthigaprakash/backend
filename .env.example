# Server
PORT=5000
NODE_ENV=development

# PostgreSQL Database
# Set DATABASE_URL for a connection string (e.g. on Render), otherwise use individual variables below
DATABASE_URL=postgresql://user:password@host:port/database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bloom_bliss
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d
